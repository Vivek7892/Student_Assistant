# For Docker/production: leave VITE_API_URL empty (nginx proxies /api → backend)
# For local dev: set to http://localhost:8000
VITE_API_URL=

# Google OAuth Client ID (must match backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# YouTube Data API v3 key
VITE_YOUTUBE_API_KEY=your-youtube-api-key

# Firebase (used for auth features)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
